DB_HOST=your-db-host
DB_PORT=3306
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_CHARSET=utf8mb4

# Segunda conexion dedicada para el widget de estado DB.
DB_STATUS_HOST=your-db-host
DB_STATUS_PORT=3306
DB_STATUS_NAME=your-db-name
DB_STATUS_USER=your-db-user
DB_STATUS_PASSWORD=your-db-password
DB_STATUS_CHARSET=utf8mb4

# Opcional: fuerza manualmente el Access Host que se muestra en Settings.
# Ejemplo: ACCESS_HOST=190.233.209.180
ACCESS_HOST=

# Fuerza uso exclusivo de MySQL (sin fallback CSV local).
# true: usa solo MySQL; false: permite fallback local CSV.
DB_FORCE_MYSQL_ONLY=true
