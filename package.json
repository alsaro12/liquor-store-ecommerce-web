{
  "name": "maqueta_visualizador",
  "version": "1.0.2",
  "main": "server.js",
  "scripts": {
    "dev": "vite --host localhost --port 3005 --strictPort",
    "dev:frontend": "npm run dev",
    "dev:react": "npm run dev",
    "dev:backend": "node server.js",
    "build": "vite build",
    "build:react": "vite build",
    "preview": "vite preview --host localhost --port 3005 --strictPort",
    "preview:react": "npm run preview",
    "serve:local": "npm run build && node serve-dist-local.js",
    "serve:storefront": "npm run serve:local",
    "serve:admin": "npm run serve:local",
    "check": "npm run check:mojibake && npm run check:syntax",
    "check:mojibake": "node scripts/check-mojibake.js",
    "check:syntax": "node scripts/check-syntax.js",
    "firebase:migrate": "node scripts/firebase-migrate-local.js",
    "firebase:migrate:dry": "node scripts/firebase-migrate-local.js --dry-run",
    "firebase:migrate:v2": "node scripts/firebase-migrate-local.js --v2",
    "firebase:migrate:v2:dry": "node scripts/firebase-migrate-local.js --v2 --dry-run",
    "user:role": "node scripts/set-user-role.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.5.0",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "style-loader": "^4.0.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  }
}
