# Base de datos MySQL
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Conexión de estado (puede ser la misma)
DB_STATUS_HOST=
DB_STATUS_PORT=3306
DB_STATUS_NAME=
DB_STATUS_USER=
DB_STATUS_PASSWORD=
DB_STATUS_CHARSET=utf8mb4

DB_FORCE_MYSQL_ONLY=false

# API base para el frontend en dev (opcional)
# VITE_API_BASE_URL=http://127.0.0.1:8787

# Firebase web app (valores publicos del proyecto Firebase)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin para migraciones locales
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_DATABASE_URL=
FIRESTORE_DATABASE_ID=
# Opciones: firestore | realtime
FIREBASE_DATABASE_ENGINE=realtime
GOOGLE_APPLICATION_CREDENTIALS=

# API base de produccion si el backend se publica separado del hosting
# VITE_API_BASE_URL=https://api.tu-dominio.com
